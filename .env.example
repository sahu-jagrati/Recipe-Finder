# ─────────────────────────────────────────────────────────────
#  Recipe Finder — API Keys
#  Copy this file to .env and fill in your keys.
#  The app works with any combination — leave a value empty
#  to skip that API entirely.
# ─────────────────────────────────────────────────────────────

# TheMealDB  ──  FREE, no key needed (already working)
# Docs: https://www.themealdb.com/api.php

# Spoonacular  ──  FREE tier: 150 points/day (~150 searches)
# Sign up: https://spoonacular.com/food-api/console#Dashboard
# 360,000+ recipes
VITE_SPOONACULAR_KEY=8f6c24a4bbe3441b849a7aa96f9de3da

# Edamam Recipe API  ──  FREE tier: 10,000 calls/month
# Sign up: https://developer.edamam.com/  →  Recipe Search API
# Get both App ID and App Key from the dashboard
# 2,300,000+ recipes
VITE_EDAMAM_APP_ID=
VITE_EDAMAM_APP_KEY=
